{
  "SeederPassword": "<your-seeder-password>",
  "Postgres": {
    "DefaultConnection": "Host=localhost;Database=starter_app;Username=postgres;Password=<your-postgres-password>"
  },
  "Authentication": {
    "APISecret": "<your-jwt-signing-secret-min-32-chars>",
    "GoogleOAuthClientId": "<your-google-oauth-client-id>",
    "GoogleOAuthClientSecret": "<your-google-oauth-client-secret>",
    "GitHubOAuthClientId": "<your-github-oauth-client-id>",
    "GitHubOAuthClientSecret": "<your-github-oauth-client-secret>"
  },
  "Email": {
    "Enabled": false,
    "AcsEndpoint": "https://<your-acs-resource>.communication.azure.com",
    "AcsAccessKey": "<your-acs-access-key>"
  }
}
